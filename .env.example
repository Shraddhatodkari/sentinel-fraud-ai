# === LLM provider for the agents (PydanticAI) ===
# Use OpenAI, Anthropic, or any provider PydanticAI supports.
# You only need ONE of these depending on which model string you use in the agents.
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# === MongoDB Atlas (audit logging) ===
# Get a free cluster at https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=sentinel

# === LangSmith (agent tracing) ===
# Free account at https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=sentinel-fraud-ai

# === App config ===
AUTO_CLEAR_CONFIDENCE_THRESHOLD=0.85
ENVIRONMENT=development
